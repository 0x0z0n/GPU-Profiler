{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "z0n-override",
  "version": "0.1.0",
  "identifier": "com.z0n.override",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "z0n // OVERRIDE PROTOCOL",
        "width": 1000,
        "height": 1280,
        "resizable": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "zenity",
          "x11-xserver-utils"
        ]
      }
    }
  }
}